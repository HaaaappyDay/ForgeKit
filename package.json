{
  "name": "forgekit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "forge": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json --noEmit",
    "test:build": "tsc -p tsconfig.test.json",
    "test": "npm run test:build && node --test .tmp/ts-tests/tests/*.test.js",
    "schema:list": "npm run build && node dist/cli.js schema list"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.0"
  }
}
