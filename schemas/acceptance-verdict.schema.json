{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "acceptance-verdict.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "node_id", "role_id", "incoming_handoff_ref", "verdict", "criteria_results", "notes"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "acceptance-verdict.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "node_id": {
      "type": "string",
      "minLength": 1
    },
    "role_id": {
      "type": "string",
      "minLength": 1
    },
    "incoming_handoff_ref": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "enum": ["accept", "reject"]
    },
    "criteria_results": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion", "met", "reason"],
        "properties": {
          "criterion": {
            "type": "string",
            "minLength": 1
          },
          "met": {
            "type": "boolean"
          },
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "notes": {
      "type": "string"
    }
  }
}
