{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "forgekit.workflow.v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "name", "version", "mode", "entrypoint", "repo_context", "steps"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "forgekit.workflow.v1"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["workflow_run"]
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "repo_context": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "role", "objective", "output_schema"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "next": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "inputs": {
            "type": "object"
          },
          "constraints": {
            "type": "object"
          },
          "output_schema": {
            "type": "string",
            "enum": ["handoff.v1"]
          }
        }
      }
    },
    "conflict_policy": {
      "type": "object"
    }
  }
}

