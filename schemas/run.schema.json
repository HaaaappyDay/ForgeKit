{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "forgekit.run.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "workflow_id",
    "status",
    "created_at",
    "updated_at",
    "started_at",
    "completed_at",
    "duration_ms",
    "task",
    "role_sessions",
    "steps",
    "budget"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "forgekit.run.v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["pending", "running", "completed", "failed"]
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "duration_ms": {
      "type": "integer",
      "minimum": 0
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["input"],
      "properties": {
        "input": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "role_sessions": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role_id", "adapter_id", "external_session_id", "resume_strategy", "created_at", "status"],
        "properties": {
          "role_id": {
            "type": "string",
            "minLength": 1
          },
          "adapter_id": {
            "type": "string",
            "minLength": 1
          },
          "external_session_id": {
            "type": "string",
            "minLength": 1
          },
          "resume_strategy": {
            "type": "string",
            "enum": ["adapter_defined", "codex_exec_resume", "claude_resume"]
          },
          "created_at": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["index", "step_id", "role_id", "adapter_id", "status", "active_attempt", "attempts"],
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 1
          },
          "step_id": {
            "type": "string",
            "minLength": 1
          },
          "role_id": {
            "type": "string",
            "minLength": 1
          },
          "adapter_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pending", "starting_session", "running", "validating", "self_correcting", "completed", "failed", "skipped"]
          },
          "active_attempt": {
            "type": "string"
          },
          "attempts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "attempt_id",
                "status",
                "started_at",
                "completed_at",
                "duration_ms",
                "prompt_ref",
                "stdout_ref",
                "stderr_ref",
                "handoff_ref",
                "markdown_ref",
                "validation_ref",
                "exit_code",
                "external_session_id",
                "correction_count",
                "error"
              ],
              "properties": {
                "attempt_id": {
                  "type": "string",
                  "minLength": 1
                },
                "status": {
                  "type": "string",
                  "enum": ["pending", "starting_session", "running", "validating", "self_correcting", "completed", "failed", "skipped"]
                },
                "started_at": {
                  "type": "string"
                },
                "completed_at": {
                  "type": "string"
                },
                "duration_ms": {
                  "type": "integer",
                  "minimum": 0
                },
                "prompt_ref": {
                  "type": "string",
                  "minLength": 1
                },
                "stdout_ref": {
                  "type": "string",
                  "minLength": 1
                },
                "stderr_ref": {
                  "type": "string",
                  "minLength": 1
                },
                "handoff_ref": {
                  "type": "string"
                },
                "markdown_ref": {
                  "type": "string"
                },
                "validation_ref": {
                  "type": "string",
                  "minLength": 1
                },
                "exit_code": {
                  "type": "integer"
                },
                "external_session_id": {
                  "type": "string"
                },
                "correction_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "error": {
                  "type": "string"
                },
                "error_code": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "max_invocations",
        "max_retries_per_step",
        "max_duration_minutes",
        "max_output_bytes",
        "invocations",
        "retries",
        "input_chars",
        "output_bytes",
        "exceeded"
      ],
      "properties": {
        "max_invocations": {
          "type": "integer",
          "minimum": 1
        },
        "max_retries_per_step": {
          "type": "integer",
          "minimum": 0
        },
        "max_duration_minutes": {
          "type": "integer",
          "minimum": 1
        },
        "max_output_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "invocations": {
          "type": "integer",
          "minimum": 0
        },
        "retries": {
          "type": "integer",
          "minimum": 0
        },
        "input_chars": {
          "type": "integer",
          "minimum": 0
        },
        "output_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "exceeded": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
