{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "forgekit.workflow.v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "name", "version", "mode", "entrypoint", "repo_context", "roles", "terminal_roles"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "forgekit.workflow.v2"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "enum": ["agentic_run"]
    },
    "entrypoint": {
      "type": "string",
      "minLength": 1
    },
    "repo_context": {
      "type": "string",
      "minLength": 1
    },
    "roles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "objective": {
            "type": "string",
            "minLength": 1
          },
          "handoff_targets": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "terminal_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "conflict_policy": {
      "type": "object"
    }
  }
}
