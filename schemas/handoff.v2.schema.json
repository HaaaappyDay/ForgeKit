{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "handoff.v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "step_id",
    "role_id",
    "status",
    "summary",
    "decisions",
    "assumptions",
    "risks",
    "open_questions",
    "out_of_scope",
    "markdown_body",
    "next_handoff",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "handoff.v2"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "step_id": {
      "type": "string",
      "minLength": 1
    },
    "role_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["decision", "reason", "alternatives"],
        "properties": {
          "decision": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "alternatives": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "out_of_scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "markdown_body": {
      "type": "string",
      "minLength": 1
    },
    "next_handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["handoff", "final"]
        },
        "recommended_role": {
          "type": "string"
        },
        "instructions": {
          "type": "string"
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "type", "generated_from"],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "generated_from": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
