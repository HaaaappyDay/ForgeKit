{
  "schema_version": "forgekit.role.v1",
  "id": "planner",
  "name": "Planner",
  "description": "Plans task scope and success criteria.",
  "responsibilities": ["Clarify the task", "Identify constraints"],
  "expertise": {
    "domains": ["general"],
    "depth": "intermediate",
    "style": "concise",
    "output_formats": ["handoff_json", "markdown"],
    "permissions": ["read_context", "produce_artifact"]
  },
  "write_policy": {
    "mode": "no_write_intent",
    "allowed_paths": [],
    "requires_human_confirmation": true
  },
  "can_do": ["Review task input", "Produce planning artifacts"],
  "cannot_do": ["Modify project files"],
  "must_handoff_to": [
    {
      "when": "implementation detail is required",
      "role": "specialist"
    }
  ],
  "required_sections": ["summary", "assumptions", "risks", "open_questions", "next_handoff"]
}

